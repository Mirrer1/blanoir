# 이 파일은 키만 기록하고 값은 비워서 git에 올림.
# 실제 값은 .env.local 에 채우고, .env.local 은 git에 올리지 않음.

# MongoDB
MONGODB_URI=

# NextAuth (Auth.js v5)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Kakao OAuth
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=

# Naver OAuth
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=

# Gmail SMTP
GMAIL_USER=
GMAIL_APP_PASSWORD=

# 사이트 URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# 검색엔진 소유권 인증
GOOGLE_SITE_VERIFICATION=
NAVER_SITE_VERIFICATION=
